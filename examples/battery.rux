  }
  .title {
    color: #9399b2;
    font-size: 14px;
  }
  .value {
    color: #a6e3a1;
    font-size: 28px;
  }
  .row {
    flex-direction: row;
    gap: 8px;
  }
  .btn {
    width: 44px;
    height: 44px;
