<template>
    <screen class="screen">
        <view class="card">
            <text class="title">Battery</text>
            <text class="value">{{ level }}%</text>
            <view class="row">
                <button class="btn" @tap="level = level - 1">
                    <text class="btnlabel">-</text>
                </button>
                <button class="btn" @tap="level = level + 1">
                    <text class="btnlabel">+</text>
                </button>
            </view>
        </view>
    </screen>
</template>

<style>
  .screen {
    flex-grow: 1;
    padding: 24px;
  }
  .card {
    width: 320px;
    flex-direction: column;
    gap: 12px;
    padding: 16px;
    background: #1e1e2e;
